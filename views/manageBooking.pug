extends base
include _sideNav

block content
  main.main
    .user-view
      nav.user-view__menu
        +sideNav('bookings')

      .user-view__content
        .user-view__form-container
          h2.heading-secondary.ma-bt-md Manage bookings

          table.manage-table
            thead
              tr
                th Tour
                th User
                th Price
                th Paid
                th Date
                th
            tbody
              each booking in bookings
                tr
                  td= booking.tour.name
                  td= booking.user.name
                  td= `$${booking.price}`
                  td= booking.paid ? 'Yes' : 'No'
                  td= new Date(booking.createdAt).toLocaleDateString('en-us', { month: 'short', day: 'numeric', year: 'numeric' })
                  td
                    button.btn.btn--small.btn--red.btn--delete-booking(data-id=booking._id) Delete
